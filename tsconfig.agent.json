{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "noEmit": true,
    "experimentalDecorators": true
  },
  "include": [
    "modules/agent/**/*.ts",
    "tests/agent/**/*.ts"
  ]
    "noEmit": true
  },
  "include": ["modules/agent/**/*.ts", "tests/agent/**/*.ts"]
}
